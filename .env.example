# ── Azure / Microsoft 365 ──
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
APP_URL=https://app.availai.net

# ── AI ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
DO_GRADIENT_API_KEY=
DO_GRADIENT_MODEL=anthropic-claude-sonnet-4-5

# ── Data Sources ──
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=
BROKERBIN_API_KEY=            # Bearer token from BrokerBin
BROKERBIN_API_SECRET=         # BrokerBin login username (e.g. triomhk)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
MOUSER_API_KEY=
OEMSECRETS_API_KEY=
SOURCENGINE_API_KEY=
ELEMENT14_API_KEY=

# ── Enrichment Providers (at least one required for Enrich / Suggested Contacts) ──
EXPLORIUM_API_KEY=

# ── 8x8 Work Analytics ──
EIGHT_BY_EIGHT_API_KEY=
EIGHT_BY_EIGHT_USERNAME=
EIGHT_BY_EIGHT_PASSWORD=
EIGHT_BY_EIGHT_PBX_ID=
EIGHT_BY_EIGHT_TIMEZONE=America/Los_Angeles
EIGHT_BY_EIGHT_ENABLED=false

# ── Email Mining ──
EMAIL_MINING_ENABLED=false

# ── Session ──
SESSION_SECRET=change-me-to-random-string

# ── Admin ──
ADMIN_EMAILS=mkhoury@trioscs.com

# ── NetComponents Worker ──
NC_USERNAME=your_nc_email@company.com
NC_PASSWORD=your_nc_password
NC_MAX_DAILY_SEARCHES=75
NC_BROWSER_PROFILE_DIR=/home/avail/nc_browser_profile

# ── Database ──
DATABASE_URL=postgresql://availai:availai@db:5432/availai
POSTGRES_USER=availai
POSTGRES_PASSWORD=availai
POSTGRES_DB=availai

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Backups ──
BACKUP_INTERVAL_HOURS=6          # How often to run pg_dump (hours)
BACKUP_RETENTION_DAYS=30         # How long to keep local backups (days)

# ── Off-site Backups (DigitalOcean Spaces — optional but recommended) ──
# DO_SPACES_KEY=                 # DigitalOcean Spaces access key
# DO_SPACES_SECRET=              # DigitalOcean Spaces secret key
# DO_SPACES_BUCKET=availai-backups
# DO_SPACES_REGION=nyc3
# SPACES_RETENTION_DAYS=90       # How long to keep remote backups
