    },
    "primary_source_name": {
      "type": "string"
    },
    "source_reference": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_first_seen_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source_last_seen_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "contact_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "contact_email": {
      "type": [
        "string",
        "null"
      ]
    },
    "contact_phone": {
      "type": [
        "string",
        "null"
      ]
    },
    "contact_url": {
      "type": [
        "string",
        "null"
      ]
    },
    "location": {
      "type": [
        "string",
        "null"
      ]
    },
