    "last_buyer_action_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "buyer_feedback_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}