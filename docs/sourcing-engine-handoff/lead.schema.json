      "type": [
        "string",
        "null"
      ]
    },
    "suggested_next_action": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "confidence_band": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "freshness_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "source_reliability_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "contactability_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "historical_success_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "reason_summary": {
      "type": "string"
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 0
    },
    "corroborated": {
      "type": "boolean"
    },
    "vendor_safety_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "vendor_safety_band": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "low_risk",
        "medium_risk",
        "high_risk",
        "unknown",
