{
  "title": "SourcingLead",
  "type": "object",
  "required": [
    "lead_id",
    "part_number_requested",
    "vendor_name",
    "vendor_name_normalized",
    "primary_source_type",
    "primary_source_name",
    "confidence_score",
    "confidence_band",
    "reason_summary",
    "buyer_status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "lead_id": {
      "type": "string"
    },
    "part_number_requested": {
      "type": "string"
    },
    "part_number_matched": {
      "type": [
        "string",
        "null"
      ]
    },
    "match_type": {
      "type": "string",
      "enum": [
        "exact",
        "normalized",
        "fuzzy",
        "cross_ref"
      ]
    },
    "vendor_name": {
      "type": "string"
    },
    "vendor_name_normalized": {
      "type": "string"
    },
