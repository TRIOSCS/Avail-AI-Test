{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: uvicorn app.main:app",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "jinja": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Pytest: current file",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "${file}",
        "-q",
        "--tb=short"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "TESTING": "1",
        "PYTHONPATH": "${workspaceFolder}"
      },
      "console": "integratedTerminal"
    }
  ]
}
