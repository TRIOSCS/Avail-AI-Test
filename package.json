{
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "if [ -f scripts/smoke-test-bundles.mjs ]; then node scripts/smoke-test-bundles.mjs; fi",
    "preview": "vite preview",
    "test:frontend": "vitest run",
    "lint": "eslint app/static/",
    "lint:fix": "eslint app/static/ --fix",
    "test:a11y": "npx playwright test --project=accessibility",
    "test:visual": "npx playwright test --project=visual",
    "test:visual:update": "npx playwright test --project=visual --update-snapshots",
    "test:html": "html-validate 'app/templates/**/*.html' || true",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:mega:python": "TESTING=1 PYTHONPATH=/root/availai pytest tests/ux_mega/ -v",
    "test:mega:playwright": "npx playwright test --project=dead-ends --project=workflows",
    "test:all-frontend": "npm run lint && npm run build && npm run test:frontend && npx playwright test && npm run test:html"
  },
