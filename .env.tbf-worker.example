# .env.tbf-worker.example — template for the TBF (The Broker Forum) browser worker.
#
# Copy to .env.tbf-worker on the host, fill in real member credentials, and
# chmod 600 (owner-only). The real file is host-only and MUST NEVER be committed
# (credentials live only here, never in the DB or git).
#
# Loaded by: deploy/avail-tbf-worker.service (EnvironmentFile)

# TBF member login (no account number — TBF authenticates on username/password)
TBF_USERNAME=
TBF_PASSWORD=

# Persistent Chrome profile (cookies survive restarts so re-login is rare)
TBF_BROWSER_PROFILE_DIR=/root/tbf_browser_profile

# Conservative rate limits (Phase 2 ramps the daily cap over ~3 weeks)
TBF_MAX_DAILY_SEARCHES=50
TBF_MAX_HOURLY_SEARCHES=10
TBF_MIN_DELAY_SECONDS=180
TBF_TYPICAL_DELAY_SECONDS=300
TBF_MAX_DELAY_SECONDS=600
TBF_DEDUP_WINDOW_DAYS=7

# Business-hours window (Eastern time)
TBF_BUSINESS_HOURS_START=8
TBF_BUSINESS_HOURS_END=18

# Safety caps
TBF_SEARCH_TIMEOUT_SECONDS=150
TBF_BREAKER_COOLDOWN_MINUTES=30
